# Copy to terraform.tfvars (gitignored). Secrets and IDs: use ./tf.sh (TF_VAR_* from 1Password).
domain = "d3hl.site"

# Mesh private routes stay disabled until tunnel IDs and routing assumptions are confirmed.
enable_mesh_private_routes = false
homelab_tunnel_id          = ""
office_tunnel_id           = ""

# Default routes the whole vlab subnet. Use "10.10.50.50/32" only if host-only routing is intended.
homelab_vlab_route = "10.10.50.0/24"

# Reverse proxy stays disabled until public hostnames and local origins are approved.
enable_homelab_reverse_proxy = false
homelab_reverse_proxy_ingress = [
  # {
  #   hostname = "resource.example.com"
  #   service  = "https://10.10.30.10:443"
  # }
]
